use HttpService as catalog {
    name = "example-http"
    image = "ghcr.io/example/http:1.0.0"
    owner = "platform-team"
    resources {
        replicas = 1
        memory = "256Mi"
    }
    metrics {
        enabled = true
        path = "/metrics"
    }
}

environment packageTest {
    use catalog

    target kubernetes {
        namespace = "package-test"
    }
}

test httpServiceBuilds {
    build packageTest
    assert catalog.workload.main.replicas == 1
}
